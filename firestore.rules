rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    // Vérifie si l'utilisateur est connecté
    function isAuthenticated() {
      return request.auth != null;
    }

    // Vérifie si l'utilisateur connecté est le propriétaire de la donnée
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // Users: Lecture publique (authentifiée), modification propriétaire uniquement
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // User Events (Badges, etc.)
    match /users/{userId}/userEvents/{eventId} {
      allow read, write: if isOwner(userId);
    }

    // User Challenges
    match /user_challenges/{challengeId} {
      // Lecture : Propriétaire uniquement
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Écriture : Création par soi-même, modif par soi-même
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Friend Requests
    match /friend_requests/{requestId} {
      // Lecture : Expéditeur ou Destinataire
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
      // Création : Seulement si on est l'expéditeur
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.fromUserId;
      // Mise à jour (Accepter/Refuser) : Concernés uniquement
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
    }

    // Sessions (Sous-collection)
    // Lecture publique (authentifiée) pour le feed social
    // Écriture propriétaire uniquement
    match /sessions/{userId}/userSessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Collection Group Queries pour les sessions (nécessaire pour le feed "tous les amis")
    match /{path=**}/userSessions/{sessionId} {
      allow read: if isAuthenticated();
    }

    // Collection Group Queries pour les événements
    match /{path=**}/userEvents/{eventId} {
      allow read: if isAuthenticated();
    }

    // Exercices par défaut — images depuis Wger (lecture seule pour tous les users connectés)
    match /default_exercises/{exerciseId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // Gym Sessions (Musculation)
    match /gym_sessions/{userId}/userGymSessions/{sessionId} {
      allow read, write: if isOwner(userId);
    }

    // User Templates
    match /userTemplates/{userId}/templates/{templateId} {
      allow read, write: if isOwner(userId);
    }

    // Exercises (Personnalisés)
    match /exercises/{exerciseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      // Création limitée à l'envoyeur ou au destinataire (pas de spam tiers)
      allow create: if isAuthenticated() &&
        (request.auth.uid == request.resource.data.userId ||
         request.auth.uid == request.resource.data.fromUserId);
      allow update: if isOwner(resource.data.userId);
    }

    // Phrases motivantes (Publiques)
    match /phrases/{phraseId} {
      allow read: if true;
      allow write: if false; // Admin seulement
    }
  }
}

